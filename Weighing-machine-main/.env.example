# ─── Weighbridge Management System ─────────────────────────────
# Copy this file to `.env` and adjust per environment.

# Environment: development | production
APP_ENV=development

# Cloud sync endpoint (used by SyncService)
CLOUD_SYNC_URL=https://api.example.com/weighbridge
CLOUD_SYNC_TOKEN=replace-with-jwt-or-api-token

# Remote closed-trip sync (PostgreSQL RDS — pull into local SQLite)
PG_SYNC_URL=postgresql://weighbridge:PASSWORD@your-rds-host:5432/postgres?sslmode=require
REMOTE_TRIP_SYNC_INTERVAL_SECONDS=30

# MCG Portal (Austere WeightBridge API — POST on ticket close only)
MCG_PORTAL_ENABLED=false
MCG_PORTAL_URL=https://sms-be.austere.biz/weightbridge
MCG_PORTAL_API_KEY=replace-with-mcg-api-key
MCG_PORTAL_TEST_MODE=false

# RFID reader (TCP/IP) — ETS-IR default port is 9090
RFID_IP=192.168.1.116
# Optional multi-reader mode (comma-separated). Example: 192.168.1.116,192.168.1.117
RFID_IPS=
RFID_PORT=9090
RFID_ANT_MASK=1
RFID_DEBOUNCE_MS=2500
RFID_SELECTION_WINDOW_MS=800
RFID_LOCK_TIMEOUT_MS=120000
RFID_ANTENNA_POWER=20
# Only accept tags whose EPC starts with this prefix (e.g. E200 series). Others are ignored.
RFID_EPC_PREFIX=E200
# Comma-separated EPCs to ignore (live scan, lock, and workflow)
RFID_BLOCKED_TAGS=E20047050D40642218490115

# Weighbridge indicator (Serial) — use a different port than the external LED display
WEIGHBRIDGE_COM_PORT=COM4
WEIGHBRIDGE_BAUD_RATE=2400
WEIGHBRIDGE_DATA_BITS=7
WEIGHBRIDGE_PARITY=none
WEIGHBRIDGE_STOP_BITS=1

# External 6-digit LED display (Serial write)
EXTERNAL_DISPLAY_ENABLED=true
EXTERNAL_DISPLAY_COM_PORT=COM3
EXTERNAL_DISPLAY_BAUD_RATE=1200
EXTERNAL_DISPLAY_DATA_BITS=8
EXTERNAL_DISPLAY_PARITY=none
EXTERNAL_DISPLAY_STOP_BITS=1
EXTERNAL_DISPLAY_CHANNEL=1
EXTERNAL_DISPLAY_COMMAND=WS1
# signed = STX + +000020 + padding + ETX (02 2B 30 30 30 30 32 30 00 00 00 03)
# ws1 = legacy WS1 command frame
EXTERNAL_DISPLAY_PROTOCOL=signed
# none = 00 00 00 checksum bytes (Docklight test); xor = XOR byte + 00 00
EXTERNAL_DISPLAY_CHECKSUM_MODE=none
EXTERNAL_DISPLAY_DECIMAL_PLACES=0

# Live camera grid (comma-separated IPs)
CAMERA_RTSP_URLS=192.168.0.88,-,192.168.0.25
CAMERA_RTSP_USER=admin
CAMERA_RTSP_PASSWORD=123456
CAMERA_RTSP_PATH=/ch01.264
CAMERA_RTSP_PORT=554
CAMERA_HTTP_SNAPSHOT_PATH=/cgi-bin/snapshot.cgi
CAMERA_HTTP_SNAPSHOT_PATHS=/cgi-bin/snapshot.cgi,/ISAPI/Streaming/channels/101/picture,/webcapture.jpg
CAMERA_PREVIEW_INTERVAL_MS=700
CAMERA_PREVIEW_TIMEOUT_MS=5000
# Require all cameras before save (set false for dev with 1 camera)
REQUIRE_CAMERA_CAPTURE=true
REQUIRED_PHOTOS=3
# Minimum working camera photos to allow Save (partial capture OK; missing slots stay empty)
MIN_PHOTOS_TO_SAVE=1
# Save-only capture; optional live preview via Show cameras button
CAMERA_PREVIEW_ON_DEMAND=true
# Operator captures photos manually, retries per camera, then Save (no auto-capture on save)
MANUAL_PHOTO_CAPTURE=true
CAMERA_CAPTURE_TIMEOUT_MS=20000
CAMERA_CAPTURE_RETRIES=3
CAMERA_CAPTURE_RETRY_DELAY_MS=400
CAMERA_FRAME_MAX_AGE_MS=5000
CAMERA_MIN_JPEG_BYTES=2048
CAMERA_BLANK_ENTROPY_MAX=4.35
CAMERA_BLANK_VARIANCE_MAX=18
# Primary camera for transaction still capture
CAMERA_RTSP_URL=rtsp://admin:123456@192.168.0.88:554/ch01.264
CAMERA_HTTP_SNAPSHOT_URL=http://admin:123456@192.168.0.88/cgi-bin/snapshot.cgi

# Sync & backup intervals
SYNC_INTERVAL_SECONDS=30
BACKUP_INTERVAL_HOURS=4
MAX_RETRY_ATTEMPTS=5

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Manual Save only — weights register when operator presses Save (always enforced in app).
MANUAL_WEIGHMENT=true

# Weight increase on loaded truck / gross only (Settings → Advance Setting; admin PIN)
WEIGHT_ADJUSTMENT_ENABLED=false
WEIGHT_OFFSET_KG=0

# Device status dots refresh (ms). Full sync-queue count refreshes on DEVICE_STATUS_FULL_INTERVAL_MS.
DEVICE_STATUS_INTERVAL_MS=2000
DEVICE_STATUS_FULL_INTERVAL_MS=10000

# Set to "true" to use mock hardware adapters during development
USE_MOCK_HARDWARE=true

# Per-device testing overrides (work even when USE_MOCK_HARDWARE=false)
USE_MOCK_WEIGHBRIDGE=true
SIMULATE_WEIGHT_KG=5000
USE_WEBCAM_CAMERA=false

# Optional explicit SQLite path (defaults to ./database/weighbridge.db)
# DB_PATH=./database/weighbridge.db

# Report header (single-vehicle PDF slip layout)
# COMPANY_NAME=MUNICIPAL CORPORATION GURUGRAM
# SITE_NAME=BANDHWARI SLF SITE GURURAM (HARYANA) DCC
# WEIGHBRIDGE_ID=WB - 03
# REPORT_COMPANY_NAME=DAYA CHARAN & COMPANY
# COMPANY_ADDRESS=
# COMPANY_PHONE=
# Customer, destination, and operator options are configured in Settings
# and selected on the weigh screen for each ticket.

# AWS S3 cloud backup (optional — can also be set in Settings → Application → Cloud backup)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=weighbridge-management-system
CLOUD_BACKUP_INTERVAL_MINUTES=60
CLOUD_LOG_UPLOAD_ENABLED=true
CLOUD_LOG_UPLOAD_INTERVAL_MINUTES=30
